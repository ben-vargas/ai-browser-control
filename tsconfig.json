{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["node", "chrome"]
  },
  "include": ["src/**/*.ts", "extension/src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
